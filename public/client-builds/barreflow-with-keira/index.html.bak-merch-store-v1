  <script>
    // BARREFLOW_LIGHTWEIGHT_CHATBOT_V1
    const chatPanel = document.getElementById("chatPanel");
    const chatBody = document.getElementById("chatBody");
    const chatForm = document.getElementById("chatForm");
    const chatText = document.getElementById("chatText");
    const chatClose = document.getElementById("chatClose");

    const chatState = {
      step: 0,
      answers: {}
    };

    const steps = [
      {
        key: "newToBarre",
        prompt: "Hi, I’m Keira’s quick assistant. Are you new to barre?",
        options: ["Yes, first time", "I’ve tried barre before", "I’m just looking"]
      },
      {
        key: "topic",
        prompt: "What would you like help with?",
        options: ["Class times", "Prices", "What to bring", "Booking"]
      },
      {
        key: "name",
        prompt: "What’s your name?",
        options: []
      },
      {
        key: "contact",
        prompt: "What email or phone number should Keira use to reply?",
        options: []
      },
      {
        key: "message",
        prompt: "Add any extra message for Keira.",
        options: []
      }
    ];

    function openChat() {
      chatPanel.classList.add("open");
      if (!chatBody.dataset.started) {
        chatBody.dataset.started = "1";
        botSay(steps[0].prompt, steps[0].options);
      }
      setTimeout(() => chatText.focus(), 150);
    }

    function closeChat() {
      chatPanel.classList.remove("open");
    }

    function botSay(text, options = []) {
      const bubble = document.createElement("div");
      bubble.className = "bubble";
      bubble.textContent = text;
      chatBody.appendChild(bubble);

      if (options.length) {
        const list = document.createElement("div");
        list.className = "quick-options";
        options.forEach(option => {
          const button = document.createElement("button");
          button.type = "button";
          button.textContent = option;
          button.addEventListener("click", () => handleReply(option));
          list.appendChild(button);
        });
        chatBody.appendChild(list);
      }

      chatBody.scrollTop = chatBody.scrollHeight;
    }

    function userSay(text) {
      const bubble = document.createElement("div");
      bubble.className = "bubble user";
      bubble.textContent = text;
      chatBody.appendChild(bubble);
      chatBody.scrollTop = chatBody.scrollHeight;
    }

    function clearOptions() {
      chatBody.querySelectorAll(".quick-options").forEach(el => el.remove());
    }

    function handleReply(text) {
      const value = String(text || "").trim();
      if (!value) return;

      clearOptions();
      userSay(value);

      const current = steps[chatState.step];
      if (current) {
        chatState.answers[current.key] = value;
      }

      chatState.step += 1;

      const next = steps[chatState.step];
      if (next) {
        setTimeout(() => botSay(next.prompt, next.options), 350);
      } else {
        setTimeout(() => {
          botSay("Thanks — Keira will get back to you shortly. For staging, I’ve logged this enquiry locally.");
          console.log("Barre Flow chat enquiry:", chatState.answers);
        }, 350);
      }
    }

    document.querySelectorAll("[data-open-chat]").forEach(button => {
      button.addEventListener("click", openChat);
    });

    chatClose.addEventListener("click", closeChat);

    chatForm.addEventListener("submit", event => {
      event.preventDefault();
      const value = chatText.value;
      chatText.value = "";
      handleReply(value);
    });

    const legacyEnquiryForm = document.getElementById("enquiryForm");
    if (legacyEnquiryForm) {
      legacyEnquiryForm.addEventListener("submit", event => {
        event.preventDefault();
        const data = Object.fromEntries(new FormData(event.currentTarget).entries());
        console.log("Barre Flow form enquiry:", data);
        alert("Thanks — this staging form has logged the enquiry locally.");
        event.currentTarget.reset();
      });
    }


    // BARREFLOW_SESSION_CALENDAR_V1
    const barreFlowSessions = {
      "mon-0930": {
        title: "Monday Mornings — Class 1",
        day: "Monday",
        time: "9:30am",
        location: "Stowmarket Community Centre, IP14 2BD",
        price: "£10 per class"
      },
      "mon-1030": {
        title: "Monday Mornings — Class 2",
        day: "Monday",
        time: "10:30am",
        location: "Stowmarket Community Centre, IP14 2BD",
        price: "£10 per class"
      },
      "wed-1800": {
        title: "Wednesday Evenings — Class 1",
        day: "Wednesday",
        time: "6:00pm",
        location: "Stowmarket Community Centre, IP14 2BD",
        price: "£10 per class"
      },
      "wed-1900": {
        title: "Wednesday Evenings — Class 2",
        day: "Wednesday",
        time: "7:00pm",
        location: "Stowmarket Community Centre, IP14 2BD",
        price: "£10 per class"
      }
    };

    const sessionCards = document.querySelectorAll("[data-session-id]");
    const selectedTitle = document.querySelector("[data-selected-title]");
    const selectedTime = document.querySelector("[data-selected-time]");
    const selectedLocation = document.querySelector("[data-selected-location]");
    const selectedPackage = document.querySelector("[data-selected-package]");
    const selectedSessionInput = document.getElementById("selectedSessionInput");
    const sessionBookingForm = document.getElementById("sessionBookingForm");
    const sessionBookingStatus = document.getElementById("sessionBookingStatus");
    const askQuestionInstead = document.getElementById("askQuestionInstead");
    const sessionQuestionPanel = document.getElementById("sessionQuestionPanel");

    function currentPackageChoice() {
      const selected = document.querySelector('input[name="package"]:checked');
      return selected ? selected.value : "Single class — £10";
    }

    function setSelectedSession(sessionId) {
      const session = barreFlowSessions[sessionId];
      if (!session) return;

      sessionCards.forEach(card => {
        card.classList.toggle("is-selected", card.dataset.sessionId === sessionId);
        card.setAttribute("aria-pressed", card.dataset.sessionId === sessionId ? "true" : "false");
      });

      selectedTitle.textContent = session.title;
      selectedTime.textContent = session.time;
      selectedLocation.textContent = session.location;
      selectedPackage.textContent = currentPackageChoice();
      selectedSessionInput.value = `${session.title}, ${session.time}`;
      selectedSessionInput.dataset.sessionId = sessionId;
    }

    sessionCards.forEach(card => {
      card.setAttribute("aria-pressed", card.classList.contains("is-selected") ? "true" : "false");
      card.addEventListener("click", () => setSelectedSession(card.dataset.sessionId));
    });

    document.querySelectorAll('input[name="package"]').forEach(input => {
      input.addEventListener("change", () => {
        selectedPackage.textContent = currentPackageChoice();
      });
    });

    if (sessionBookingForm) {
      sessionBookingForm.addEventListener("submit", event => {
        event.preventDefault();
        const data = Object.fromEntries(new FormData(sessionBookingForm).entries());
        data.sessionId = selectedSessionInput.dataset.sessionId || "wed-1800";
        console.log("Barre Flow session reservation prototype:", data);
        sessionBookingStatus.textContent = "Payment checkout placeholder. Stripe will be connected after final pricing approval.";
      });
    }

    if (askQuestionInstead && sessionQuestionPanel) {
      askQuestionInstead.addEventListener("click", () => {
        sessionQuestionPanel.classList.toggle("is-open");
      });
    }

    setSelectedSession("wed-1800");
  </script>
