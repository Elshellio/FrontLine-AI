  <link rel="preload" as="image" href="./assets/final/about.webp">

  <style>
    :root {
      --ink: #211719;
      --muted: #6f5d60;
      --cream: #fff8f4;
      --cream-2: #f7ece8;
      --blush: #c97883;
      --blush-2: #b66370;
      --rose-dark: #7b3f4b;
      --line: rgba(123, 63, 75, .18);
      --glass: rgba(255, 250, 246, .72);
      --glass-strong: rgba(255, 250, 246, .88);
      --shadow: 0 28px 90px rgba(84, 46, 47, .16);
      --shadow-soft: 0 18px 50px rgba(84, 46, 47, .10);
      --radius: 30px;
      --max: 1180px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at 12% 4%, rgba(201,120,131,.18), transparent 34rem),
        radial-gradient(circle at 88% 18%, rgba(236,199,187,.34), transparent 34rem),
        linear-gradient(180deg, #fffaf7 0%, #f8eee9 48%, #fffaf7 100%);
      overflow-x: hidden;
    }

    h1, h2, h3 {
      font-family: Georgia, "Times New Roman", serif;
      letter-spacing: -.04em;
      line-height: .95;
      margin: 0;
      color: var(--ink);
    }

    h1 { font-size: clamp(4rem, 10vw, 8.6rem); max-width: 760px; }
    h2 { font-size: clamp(2.7rem, 5.8vw, 5.4rem); max-width: 850px; }
    h3 { font-size: clamp(1.35rem, 2.2vw, 2.15rem); }

    p {
      margin: 0;
      color: var(--muted);
      font-size: 1.03rem;
      line-height: 1.72;
    }

    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }

    .wrap {
      width: min(var(--max), calc(100% - 44px));
      margin-inline: auto;
    }

    .eyebrow {
      text-transform: uppercase;
      letter-spacing: .2em;
      color: var(--rose-dark);
      font-size: .76rem;
      font-weight: 900;
      margin-bottom: 1rem;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: .92rem 1.35rem;
      border-radius: 999px;
      border: 1px solid transparent;
      font-weight: 900;
      font-size: .92rem;
      letter-spacing: .01em;
      cursor: pointer;
      transition: transform .2s ease, box-shadow .2s ease, background .2s ease, border-color .2s ease;
      white-space: nowrap;
    }

    .button.primary {
      background: linear-gradient(135deg, var(--blush), var(--rose-dark));
      color: white;
      box-shadow: 0 18px 42px rgba(123, 63, 75, .25);
    }

    .button.secondary {
      background: rgba(255,255,255,.72);
      color: var(--rose-dark);
      border-color: rgba(123,63,75,.24);
      backdrop-filter: blur(16px);
    }

    .button.light {
      background: #fffaf7;
      color: var(--rose-dark);
      border-color: rgba(255,255,255,.5);
    }

    .button:hover {
      transform: translateY(-2px);
      box-shadow: 0 24px 54px rgba(123, 63, 75, .22);
    }

    .site-nav {
      position: fixed;
      top: 18px;
      left: 0;
      right: 0;
      z-index: 50;
      pointer-events: none;
    }

    .nav-shell {
      pointer-events: auto;
      width: min(1180px, calc(100% - 36px));
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: .78rem .9rem .78rem 1.25rem;
      border: 1px solid rgba(123,63,75,.14);
      background: rgba(255,250,246,.76);
      backdrop-filter: blur(22px);
      border-radius: 999px;
      box-shadow: 0 16px 60px rgba(84,46,47,.12);
    }

    .brand {
      display: flex;
      flex-direction: column;
      line-height: 1;
      font-family: Georgia, "Times New Roman", serif;
      font-size: 1.28rem;
      letter-spacing: -.03em;
      font-weight: 700;
    }

    .brand small {
      font-family: Inter, system-ui, sans-serif;
      color: var(--blush-2);
      font-size: .67rem;
      text-transform: uppercase;
      letter-spacing: .18em;
      margin-top: .22rem;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      font-size: .88rem;
      font-weight: 800;
      color: #3a292c;
    }

    .nav-links a:hover { color: var(--rose-dark); }

    .nav-cta {
      min-height: 40px;
      padding: .72rem 1.05rem;
      font-size: .82rem;
    }

    .hero {
      position: relative;
      min-height: 100svh;
      display: grid;
      align-items: end;
      padding: 7rem 0 4.2rem;
      overflow: hidden;
      isolation: isolate;
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -3;
      background:
        linear-gradient(90deg, rgba(255,248,244,.98) 0%, rgba(255,248,244,.72) 38%, rgba(255,248,244,.20) 68%, rgba(255,248,244,.08) 100%),
        linear-gradient(180deg, rgba(33,23,25,.02), rgba(33,23,25,.18)),
        url("./assets/final/hero.webp") center / cover no-repeat;
      transform: scale(1.015);
    }

    .hero::after {
      content: "";
      position: absolute;
      inset: auto 0 0;
      height: 28%;
      z-index: -2;
      background: linear-gradient(180deg, transparent, #fff8f4);
    }

    .hero-glow {
      position: absolute;
      width: 42rem;
      height: 42rem;
      border-radius: 999px;
      background: rgba(201,120,131,.22);
      filter: blur(80px);
      left: -12rem;
      bottom: -12rem;
      z-index: -1;
    }

    .hero-card {
      width: min(720px, 100%);
      padding: clamp(1.45rem, 4vw, 3rem);
      border-radius: var(--radius);
      border: 1px solid rgba(123,63,75,.18);
      background: linear-gradient(135deg, rgba(255,250,246,.86), rgba(255,250,246,.62));
      backdrop-filter: blur(22px);
      box-shadow: var(--shadow);
    }

    .hero-card p {
      max-width: 560px;
      font-size: clamp(1rem, 1.5vw, 1.2rem);
      color: #4b373b;
      margin-top: 1rem;
    }

    .hero-sub {
      margin-top: 1rem;
      color: var(--rose-dark);
      font-size: clamp(1.1rem, 2vw, 1.55rem);
      font-weight: 900;
      letter-spacing: -.02em;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: .9rem;
      margin-top: 1.4rem;
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: .7rem;
      margin-top: 1.45rem;
    }

    .chip {
      display: inline-flex;
      align-items: center;
      gap: .45rem;
      padding: .65rem .85rem;
      border: 1px solid rgba(123,63,75,.18);
      background: rgba(255,255,255,.62);
      border-radius: 999px;
      color: #52383e;
      font-weight: 850;
      font-size: .85rem;
      backdrop-filter: blur(14px);
    }

    .chip::before {
      content: "";
      width: .5rem;
      height: .5rem;
      border-radius: 999px;
      background: var(--blush);
      box-shadow: 0 0 0 5px rgba(201,120,131,.13);
    }

    section {
      position: relative;
      padding: clamp(4.5rem, 8vw, 7.5rem) 0;
    }

    .section-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 460px);
      gap: clamp(1.5rem, 5vw, 4rem);
      align-items: end;
      margin-bottom: 2rem;
    }

    .panel {
      border: 1px solid var(--line);
      background: linear-gradient(145deg, rgba(255,255,255,.78), rgba(255,248,244,.50));
      backdrop-filter: blur(18px);
      border-radius: var(--radius);
      box-shadow: var(--shadow-soft);
    }

    .intro-grid {
      display: grid;
      grid-template-columns: 1.05fr .95fr;
      gap: 1.4rem;
      align-items: stretch;
    }

    .intro-copy {
      padding: clamp(1.4rem, 3vw, 2.3rem);
    }

    .steps {
      padding: 1rem;
      display: grid;
      gap: .85rem;
    }

    .step {
      display: grid;
      grid-template-columns: 42px 1fr;
      gap: .9rem;
      padding: 1.05rem;
      border-radius: 22px;
      background: rgba(255,255,255,.68);
      border: 1px solid rgba(123,63,75,.10);
    }

    .num {
      width: 42px;
      height: 42px;
      border-radius: 16px;
      display: grid;
      place-items: center;
      background: rgba(201,120,131,.14);
      color: var(--rose-dark);
      font-weight: 950;
    }

    .step strong, .benefit-card strong, .class-card strong {
      display: block;
      margin-bottom: .25rem;
      color: var(--ink);
      font-size: 1.05rem;
    }

    .benefits-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1rem;
    }

    .benefit-card {
      padding: 1.25rem;
      min-height: 180px;
      border-radius: 26px;
      border: 1px solid var(--line);
      background:
        radial-gradient(circle at 100% 0%, rgba(201,120,131,.16), transparent 9rem),
        rgba(255,255,255,.68);
      box-shadow: var(--shadow-soft);
    }

    .benefit-icon {
      width: 42px;
      height: 42px;
      border-radius: 16px;
      display: grid;
      place-items: center;
      margin-bottom: 1rem;
      color: var(--rose-dark);
      background: rgba(201,120,131,.14);
      font-weight: 950;
    }

    .classes-grid {
      display: grid;
      gap: .95rem;
    }

    .class-card {
      display: grid;
      grid-template-columns: 1fr 1.5fr auto;
      gap: 1.2rem;
      align-items: center;
      padding: 1.15rem;
      border-radius: 26px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,.72);
      box-shadow: 0 12px 34px rgba(84,46,47,.07);
    }

    .tag {
      display: inline-flex;
      width: fit-content;
      margin-top: .2rem;
      padding: .32rem .55rem;
      border-radius: 999px;
      background: rgba(201,120,131,.12);
      color: var(--rose-dark);
      font-size: .72rem;
      font-weight: 950;
      text-transform: uppercase;
      letter-spacing: .08em;
    }

    .about {
      background:
        radial-gradient(circle at 10% 20%, rgba(201,120,131,.12), transparent 28rem),
        linear-gradient(180deg, rgba(255,255,255,.22), rgba(255,248,244,.72));
    }

    .about-grid {
      display: grid;
      grid-template-columns: .95fr 1.05fr;
      gap: clamp(1.4rem, 5vw, 4rem);
      align-items: center;
    }

    .image-card {
      position: relative;
      padding: .7rem;
      border-radius: 34px;
      overflow: hidden;
    }

    .image-card img {
      width: 100%;
      aspect-ratio: 4 / 4.7;
      object-fit: cover;
      border-radius: 26px;
      box-shadow: inset 0 0 0 1px rgba(255,255,255,.3);
    }

    .image-badge {
      position: absolute;
      left: 1.35rem;
      bottom: 1.35rem;
      padding: .8rem 1rem;
      border-radius: 18px;
      background: rgba(255,250,246,.82);
      border: 1px solid rgba(123,63,75,.16);
      backdrop-filter: blur(16px);
      box-shadow: 0 14px 40px rgba(84,46,47,.14);
      font-weight: 950;
      color: var(--rose-dark);
    }

    .about-copy {
      padding: clamp(1.4rem, 3.5vw, 3rem);
    }

    .about-copy p + p { margin-top: .9rem; }

    .booking {
      padding: clamp(4rem, 8vw, 7rem) 0;
      background:
        linear-gradient(90deg, rgba(44,30,30,.88), rgba(123,63,75,.64)),
        url("./assets/final/cta.webp") center / cover no-repeat;
      color: white;
    }

    .booking h2, .booking p, .booking .eyebrow { color: white; }
    .booking p { opacity: .92; }

    .booking-grid {
      display: grid;
      grid-template-columns: 1fr minmax(300px, 440px);
      gap: clamp(1.3rem, 5vw, 4rem);
      align-items: center;
    }

    .payment-card {
      padding: 1.25rem;
      border-radius: 30px;
      border: 1px solid rgba(255,255,255,.28);
      background: rgba(255,255,255,.12);
      backdrop-filter: blur(18px);
      box-shadow: 0 28px 80px rgba(0,0,0,.22);
    }

    .payment-card .button {
      width: 100%;
      margin-top: .7rem;
    }

    .payment-note {
      margin-top: .9rem;
      font-size: .9rem;
      color: rgba(255,255,255,.82);
    }


    /* BARREFLOW_SESSION_CALENDAR_V1 */
    .bf-session-calendar-section {
      position: relative;
      overflow: hidden;
      padding: clamp(4.2rem, 8vw, 7rem) 0;
      background:
        radial-gradient(circle at 9% 14%, rgba(255,255,255,.86) 0 92px, transparent 93px),
        radial-gradient(circle at 86% 10%, rgba(242,220,224,.78) 0 118px, transparent 119px),
        radial-gradient(circle at 72% 86%, rgba(255,255,255,.72) 0 84px, transparent 85px),
        linear-gradient(135deg, #fff8f4 0%, #f8e9e7 52%, #fffaf6 100%);
      border-top: 1px solid rgba(123,63,75,.12);
    }

    .bf-session-calendar-section::before,
    .bf-session-calendar-section::after {
      content: "";
      position: absolute;
      border-radius: 999px;
      pointer-events: none;
      border: 1px solid rgba(201,120,131,.16);
      background: rgba(255,255,255,.28);
      box-shadow: inset 0 0 0 18px rgba(255,255,255,.18);
    }

    .bf-session-calendar-section::before {
      width: 210px;
      height: 210px;
      left: -80px;
      top: 18%;
    }

    .bf-session-calendar-section::after {
      width: 280px;
      height: 280px;
      right: -120px;
      bottom: 10%;
    }

    .bf-session-shell {
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(330px, .8fr);
      gap: clamp(1.1rem, 3vw, 2rem);
      align-items: start;
      z-index: 1;
    }

    .bf-session-intro,
    .bf-session-booking-panel,
    .bf-session-group {
      border: 1px solid rgba(123,63,75,.15);
      background: rgba(255,255,255,.54);
      backdrop-filter: blur(18px);
      box-shadow: 0 24px 70px rgba(84,46,47,.12);
      border-radius: 30px;
    }

    .bf-session-intro {
      padding: clamp(1.35rem, 3vw, 2.2rem);
      margin-bottom: 1rem;
    }

    .bf-session-intro h2 { max-width: 820px; }
    .bf-session-intro > p { max-width: 760px; }

    .bf-schedule-note {
      margin: 1.2rem 0 0;
      padding: .9rem 1rem;
      border-radius: 22px;
      border: 1px solid rgba(201,120,131,.22);
      background: rgba(242,220,224,.58);
      color: #6b3b43;
      font-weight: 800;
    }

    .bf-price-chips {
      display: flex;
      flex-wrap: wrap;
      gap: .55rem;
      margin-top: 1rem;
    }

    .bf-price-chip {
      display: inline-flex;
      align-items: center;
      gap: .4rem;
      min-height: 38px;
      padding: .5rem .8rem;
      border-radius: 999px;
      border: 1px solid rgba(123,63,75,.16);
      background: rgba(255,255,255,.7);
      color: #6b3b43;
      font-weight: 900;
      box-shadow: 0 10px 24px rgba(84,46,47,.06);
    }

    .bf-session-groups {
      display: grid;
      gap: 1rem;
    }

    .bf-session-group {
      padding: 1rem;
    }

    .bf-session-group-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 1rem;
      padding: .3rem .35rem .9rem;
      border-bottom: 1px solid rgba(123,63,75,.11);
    }

    .bf-session-group-head h3 {
      margin: 0;
      font-size: clamp(1.45rem, 4vw, 2rem);
    }

    .bf-launch-pill {
      display: inline-flex;
      align-items: center;
      white-space: nowrap;
      border-radius: 999px;
      padding: .45rem .7rem;
      background: #7b3f4b;
      color: #fff;
      font-size: .78rem;
      font-weight: 900;
    }

    .bf-session-card-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: .75rem;
      padding-top: .9rem;
    }

    .bf-session-card {
      position: relative;
      text-align: left;
      width: 100%;
      border: 1px solid rgba(123,63,75,.14);
      border-radius: 24px;
      padding: 1rem;
      background: rgba(255,255,255,.66);
      color: var(--ink);
      cursor: pointer;
      box-shadow: 0 16px 34px rgba(84,46,47,.08);
      transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease, background .2s ease;
    }

    .bf-session-card:hover {
      transform: translateY(-3px);
      border-color: rgba(123,63,75,.32);
      box-shadow: 0 22px 48px rgba(84,46,47,.13);
    }

    .bf-session-card.is-primary {
      background: linear-gradient(145deg, rgba(255,255,255,.78), rgba(242,220,224,.72));
      border-color: rgba(123,63,75,.26);
    }

    .bf-session-card.is-selected {
      background: #7b3f4b;
      border-color: #7b3f4b;
      color: #fff;
      box-shadow: 0 26px 60px rgba(123,63,75,.28);
    }

    .bf-session-card.is-selected p,
    .bf-session-card.is-selected .bf-session-meta,
    .bf-session-card.is-selected .bf-session-price { color: rgba(255,255,255,.86); }

    .bf-session-day {
      display: block;
      margin-bottom: .4rem;
      font-size: .78rem;
      font-weight: 950;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--rose-dark);
    }

    .bf-session-card.is-selected .bf-session-day { color: #f8dfe3; }

    .bf-session-card strong {
      display: block;
      font-family: Georgia, "Times New Roman", serif;
      font-size: 1.26rem;
      line-height: 1.1;
    }

    .bf-session-meta,
    .bf-session-price {
      display: block;
      margin-top: .45rem;
      color: var(--muted);
      font-size: .92rem;
    }

    .bf-session-booking-panel {
      position: sticky;
      top: 96px;
      padding: clamp(1.25rem, 3vw, 1.65rem);
    }

    .bf-selected-summary {
      display: grid;
      gap: .55rem;
      margin: 1rem 0;
      padding: 1rem;
      border-radius: 24px;
      border: 1px solid rgba(123,63,75,.14);
      background: rgba(255,248,244,.74);
    }

    .bf-selected-summary strong {
      font-family: Georgia, "Times New Roman", serif;
      font-size: 1.2rem;
      color: #352529;
    }

    .bf-selected-summary span { color: var(--muted); }

    .bf-booking-form {
      display: grid;
      gap: .9rem;
    }

    .bf-package-options {
      display: grid;
      gap: .55rem;
    }

    .bf-package-option {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: .8rem;
      padding: .78rem .85rem;
      border-radius: 20px;
      border: 1px solid rgba(123,63,75,.14);
      background: rgba(255,255,255,.62);
      cursor: pointer;
      color: #352529;
    }

    .bf-package-option:has(input:checked) {
      border-color: rgba(123,63,75,.42);
      background: rgba(242,220,224,.66);
      box-shadow: 0 10px 26px rgba(84,46,47,.08);
    }

    .bf-package-option input { width: auto; accent-color: #7b3f4b; }
    .bf-package-option span { font-weight: 900; }

    .bf-form-status,
    .bf-question-panel {
      min-height: 24px;
      margin: .2rem 0 0;
      color: #6b3b43;
      font-size: .9rem;
      font-weight: 800;
    }

    .bf-question-panel {
      display: none;
      padding: .9rem;
      border-radius: 22px;
      border: 1px solid rgba(123,63,75,.14);
      background: rgba(255,255,255,.58);
    }

    .bf-question-panel.is-open { display: grid; gap: .7rem; }

    .bf-secondary-action {
      border: 0;
      background: transparent;
      color: #7b3f4b;
      font-weight: 950;
      text-decoration: underline;
      text-underline-offset: 4px;
      cursor: pointer;
      padding: .35rem 0;
    }

    @media (max-width: 900px) {
      .bf-session-shell { grid-template-columns: 1fr; }
      .bf-session-booking-panel { position: static; }
      .bf-session-card-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 560px) {
      .bf-session-calendar-section { padding-inline: 0; }
      .bf-session-intro,
      .bf-session-booking-panel,
      .bf-session-group { border-radius: 24px; }
      .bf-session-group-head { align-items: flex-start; flex-direction: column; }
