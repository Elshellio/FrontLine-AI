<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Frontline AI | AI Workers. Real Results.</title>
<style>
:root{
  --bg:#030711;
  --panel:#07111f;
  --blue:#0f75ff;
  --blue2:#36a3ff;
  --text:#ffffff;
  --muted:#aebbd0;
  --line:rgba(255,255,255,.14);
}
*{box-sizing:border-box}
html,body{margin:0;background:var(--bg);color:var(--text);font-family:Arial,Helvetica,sans-serif}
a{text-decoration:none;color:inherit}
img{display:block}
.page{overflow:hidden;background:#030711}
.shell{max-width:1500px;margin:0 auto;padding:0 48px}

.hero{
  min-height:760px;
  position:relative;
  background:
    linear-gradient(90deg,rgba(3,7,17,.98) 0%,rgba(3,7,17,.92) 34%,rgba(3,7,17,.25) 57%,rgba(3,7,17,.04) 100%),
    url('/assets/7.png') right center/auto 100% no-repeat;
}
.hero:before{
  content:"";
  position:absolute;inset:0;
  background:url('/assets/9.png') left bottom/70% auto no-repeat;
  opacity:.62;
  pointer-events:none;
}
.nav{
  position:relative;z-index:2;
  height:94px;
  display:flex;align-items:center;justify-content:space-between;
}
.logo{height:46px;width:auto}
.navlinks{display:flex;gap:34px;align-items:center;color:#dbe6f5;font-size:15px}
.navActions{display:flex;gap:14px}
.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:12px;
  height:52px;padding:0 26px;border-radius:8px;
  font-weight:800;font-size:15px;
  border:1px solid var(--line);
}
.btn.blue{background:var(--blue);border-color:var(--blue);box-shadow:0 18px 55px rgba(15,117,255,.28)}
.btn.dark{background:rgba(5,11,22,.35)}
.content{
  position:relative;z-index:2;
  padding-top:95px;
  max-width:650px;
}
.kicker{
  color:#69a9ff;
  font-size:13px;
  letter-spacing:.22em;
  text-transform:uppercase;
  font-weight:900;
  margin-bottom:24px;
}
h1{
  margin:0;
  font-size:84px;
  line-height:.92;
  letter-spacing:-.065em;
}
.blueText{color:var(--blue)}
.lead{
  margin:28px 0 34px;
  color:#d3deee;
  font-size:22px;
  line-height:1.48;
  max-width:610px;
}
.heroBtns{display:flex;gap:16px;align-items:center}

.ops{
  position:relative;z-index:3;
  margin-top:70px;
  display:grid;
  grid-template-columns:repeat(5,1fr);
  background:rgba(4,10,20,.82);
  border:1px solid var(--line);
  border-radius:16px;
  backdrop-filter:blur(18px);
  box-shadow:0 24px 80px rgba(0,0,0,.45);
}
.op{
  padding:24px 26px;
  display:flex;gap:18px;align-items:center;
  border-right:1px solid var(--line);
}
.op:last-child{border-right:0}
.opIcon{
  font-size:34px;
  color:var(--blue);
  line-height:1;
}
.op b{display:block;font-size:15px;text-transform:uppercase;letter-spacing:.06em}
.op span{display:block;color:#c4d0e2;font-size:14px;margin-top:5px}

.proof{
  position:relative;z-index:3;
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:0;
  border-top:1px solid var(--line);
  border-bottom:1px solid var(--line);
  background:#050b16;
}
.proof .item{
  padding:24px 40px;
  border-right:1px solid var(--line);
}
.proof .item:last-child{border-right:0}
.proof b{font-size:15px;text-transform:uppercase;color:#f3f7ff}
.proof p{margin:6px 0 0;color:#9facbf;font-size:14px}

.section{
  background:linear-gradient(180deg,#050b16 0%,#071426 100%);
  padding:70px 0 90px;
}
.grid{
  display:grid;
  grid-template-columns:.82fr 1.18fr;
  gap:58px;
  align-items:center;
}
.section h2{
  margin:0;
  font-size:52px;
  line-height:1.02;
  letter-spacing:-.045em;
}
.section p{
  margin:24px 0 0;
  color:#bdc9db;
  font-size:20px;
  line-height:1.55;
}
.industryCards{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:12px;
}
.card{
  position:relative;
  height:330px;
  border-radius:18px;
  overflow:hidden;
  border:1px solid rgba(255,255,255,.13);
  background:#111;
  box-shadow:0 24px 70px rgba(0,0,0,.35);
}
.card img{
  width:100%;height:100%;object-fit:cover;
  filter:saturate(1.05) contrast(1.06);
}
.card:after{
  content:"";
  position:absolute;inset:0;
  background:linear-gradient(180deg,rgba(0,0,0,.05),rgba(0,0,0,.76));
}
.cardLabel{
  position:absolute;
  left:18px;right:18px;bottom:18px;
  z-index:2;
}
.cardLabel small{
  color:#75b4ff;
  font-weight:900;
  letter-spacing:.14em;
  text-transform:uppercase;
  font-size:11px;
}
.cardLabel b{
  display:block;
  font-size:22px;
  margin-top:5px;
}
.finalCta{
  background:#02050c;
  padding:64px 0;
  border-top:1px solid var(--line);
}
.ctaBox{
  border-radius:24px;
  padding:42px 46px;
  background:
    linear-gradient(90deg,rgba(15,117,255,.22),rgba(15,117,255,.04)),
    url('/assets/9.png') right center/55% auto no-repeat;
  border:1px solid var(--line);
  display:flex;align-items:center;justify-content:space-between;gap:30px;
}
.ctaBox h2{font-size:42px;margin:0;letter-spacing:-.04em}
.ctaBox p{margin:10px 0 0;color:#bcc9da;font-size:18px}

@media(max-width:1000px){
  .shell{padding:0 24px}
  .navlinks{display:none}
  .hero{background:linear-gradient(180deg,rgba(3,7,17,.92),rgba(3,7,17,.65)),url('/assets/7.png') center/cover no-repeat}
  h1{font-size:56px}
  .ops,.proof,.grid,.industryCards{grid-template-columns:1fr}
  .op,.proof .item{border-right:0;border-bottom:1px solid var(--line)}
  .card{height:420px}
  .ctaBox{display:block}
  .ctaBox .btn{margin-top:24px}
}
</style>
</head>
<body>
<div class="page">

  <header class="hero">
    <div class="shell">
      <nav class="nav">
        <img class="logo" src="/assets/2.png" alt="Frontline AI">
        <div class="navlinks">
          <a href="#how">How It Works</a>
          <a href="#industries">Industries</a>
          <a href="#pricing">Pricing</a>
          <a href="#resources">Resources</a>
        </div>
        <div class="navActions">
          <a class="btn dark" href="#">Log In</a>
          <a class="btn blue" href="mailto:gary.shelley1@gmail.com?subject=Frontline%20AI%20Demo">Book Demo →</a>
        </div>
      </nav>

      <div class="content">
        <div class="kicker">AI workers for service businesses</div>
        <h1>AI WORKERS.<br><span class="blueText">REAL RESULTS.</span></h1>
        <p class="lead">
          Frontline AI deploys intelligent AI workers that answer, qualify,
          book and follow up — 24/7. So you never miss a lead and never lose revenue.
        </p>
        <div class="heroBtns">
          <a class="btn blue" href="mailto:gary.shelley1@gmail.com?subject=Frontline%20AI%20Demo">Book Demo →</a>
          <a class="btn dark" href="#industries">See How It Works ◉</a>
        </div>
      </div>

      <div class="ops">
        <div class="op"><div class="opIcon">☎</div><div><b>Answer</b><span>Every call</span></div></div>
        <div class="op"><div class="opIcon">▣</div><div><b>Book</b><span>More appointments</span></div></div>
        <div class="op"><div class="opIcon">◉</div><div><b>Qualify</b><span>Better leads</span></div></div>
        <div class="op"><div class="opIcon">▱</div><div><b>Follow up</b><span>Automatically</span></div></div>
        <div class="op"><div class="opIcon">↗</div><div><b>Grow</b><span>More revenue</span></div></div>
      </div>
    </div>
  </header>

  <div class="proof">
    <div class="item"><b>Secure & compliant</b><p>Built for business-critical conversations.</p></div>
    <div class="item"><b>24/7/365</b><p>Always on. Never miss.</p></div>
    <div class="item"><b>Built for service businesses</b><p>Reception, booking, intake and follow-up.</p></div>
    <div class="item"><b>Start with one worker</b><p>Scale when the first one proves value.</p></div>
  </div>

  <section class="section" id="industries">
    <div class="shell grid">
      <div>
        <div class="kicker">Deploy by industry</div>
        <h2>Your first AI employee is <span class="blueText">just the beginning.</span></h2>
        <p>
          Start with one AI worker. Add more as you grow.
          Frontline AI fits around real business operations — not generic chatbot templates.
        </p>
        <div style="margin-top:34px">
          <a class="btn blue" href="mailto:gary.shelley1@gmail.com?subject=Frontline%20AI%20Industries">Explore Industries →</a>
        </div>
      </div>

      <div class="industryCards">
        <div class="card"><img src="/assets/10.png" alt=""><div class="cardLabel"><small>AI Intake</small><b>Legal</b></div></div>
        <div class="card"><img src="/assets/11.png" alt=""><div class="cardLabel"><small>AI Service Advisor</small><b>Garages</b></div></div>
        <div class="card"><img src="/assets/12.png" alt=""><div class="cardLabel"><small>AI Coordinator</small><b>Clinics</b></div></div>
        <div class="card"><img src="/assets/13.png" alt=""><div class="cardLabel"><small>AI Concierge</small><b>Hospitality</b></div></div>
      </div>
    </div>
  </section>

  <section class="finalCta">
    <div class="shell">
      <div class="ctaBox">
        <div>
          <h2>Your AI workforce is ready. Let’s put it to work.</h2>
          <p>Book a practical demo and see where AI workers can start inside your business.</p>
        </div>
        <a class="btn blue" href="mailto:gary.shelley1@gmail.com?subject=Frontline%20AI%20Demo">Book Demo →</a>
      </div>
    </div>
  </section>

</div>
</body>
</html>
