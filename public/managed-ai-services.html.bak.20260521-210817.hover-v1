<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Managed AI Services | Frontline AI</title>
  <meta name="description" content="Frontline AI can run practical AI services around reception, missed leads, bookings, callbacks, website assistants and growth intelligence — so the business gets results without having to operate the system itself.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/frontline-menu.css?v=20260521-menu-exact-v2">
  <link rel="stylesheet" href="/assets/frontline-assistant.css?v=20260520-frontline-assistant-v1">
  <style>
    :root{--bg:#03070f;--panel:rgba(8,18,36,.72);--text:#f7fbff;--muted:#aebbd0;--line:rgba(112,184,255,.25);--blue:#1678ff;--cyan:#62d8ff;--violet:#915cff;--gold:#f2dc9d}
    *{box-sizing:border-box}
    body{margin:0;font-family:Inter,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;color:var(--text);background:#03070f}
    body:before{content:"";position:fixed;inset:0;background:linear-gradient(90deg,rgba(2,6,16,.92),rgba(2,6,16,.54)),url("/assets/websites-home-new/background999.png") center/cover no-repeat;opacity:.95;pointer-events:none}
    a{color:inherit;text-decoration:none}
    .page{position:relative;z-index:1}
    .wrap{width:min(1180px,calc(100% - 40px));margin:0 auto}
    .top{padding:26px 0 8px}
    .nav{display:flex;justify-content:space-between;align-items:center;gap:18px;padding:14px 16px;border:1px solid var(--line);border-radius:28px;background:rgba(5,14,30,.72);backdrop-filter:blur(18px);box-shadow:0 24px 70px rgba(0,0,0,.30),inset 0 1px 0 rgba(255,255,255,.08)}
    .brand{display:flex;align-items:center;gap:12px;font-weight:950}
    .brand img{width:46px;height:46px;border-radius:16px;object-fit:contain;border:1px solid var(--line);background:rgba(255,255,255,.04)}
    .nav a.btn{padding:12px 18px;border-radius:999px;background:linear-gradient(135deg,var(--blue),var(--cyan));font-weight:900}
    .hero{padding:86px 0 56px}
    .heroGrid{display:grid;grid-template-columns:minmax(0,.92fr) minmax(420px,1.08fr);gap:42px;align-items:center}
    .eyebrow{display:inline-flex;padding:9px 13px;border:1px solid var(--line);border-radius:999px;color:#8fd4ff;background:rgba(22,120,255,.10);font-size:11px;font-weight:950;letter-spacing:.18em;text-transform:uppercase}
    h1{font-family:Georgia,serif;font-size:clamp(50px,6.6vw,92px);line-height:.92;letter-spacing:-.055em;font-weight:500;margin:24px 0 18px}
    h1 span{color:#62d8ff}
    .lead{max-width:680px;color:#d0dae8;font-size:18px;line-height:1.68}
    .actions{display:flex;gap:14px;flex-wrap:wrap;margin-top:30px}
    .btn{display:inline-flex;align-items:center;justify-content:center;min-height:48px;padding:0 20px;border:1px solid rgba(125,205,255,.36);border-radius:999px;background:rgba(2,7,18,.48);font-weight:900}
    .btn.primary{background:linear-gradient(135deg,var(--blue),var(--violet));border-color:rgba(255,255,255,.26)}
    .visual{min-height:470px;border:1px solid rgba(125,205,255,.28);border-radius:34px;background:linear-gradient(180deg,rgba(2,6,16,.05),rgba(2,6,16,.48)),url("/assets/websites-final/website-dashboard-handoff.png") center/cover no-repeat;box-shadow:0 34px 100px rgba(0,0,0,.40),0 0 70px rgba(40,120,255,.22);position:relative;overflow:hidden}
    .visual:after{content:"Managed AI Services";position:absolute;left:24px;right:24px;bottom:24px;padding:18px 20px;border:1px solid rgba(255,255,255,.14);border-radius:24px;background:rgba(2,7,18,.68);backdrop-filter:blur(16px);color:#e8f4ff;font-size:22px;font-weight:950}
    section{padding:52px 0}
    .sectionHead{display:grid;grid-template-columns:minmax(0,.9fr) minmax(320px,.7fr);gap:34px;align-items:end;margin-bottom:24px}
    .sectionHead h2{font-family:Georgia,serif;font-size:clamp(34px,4vw,58px);line-height:1.02;font-weight:500;margin:0}
    .sectionHead p{margin:0;color:#b9c6d6;font-size:17px;line-height:1.65}
    .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
    .offerCard,.proofItem{border:1px solid rgba(112,184,255,.24);border-radius:28px;background:linear-gradient(145deg,rgba(10,24,46,.76),rgba(4,10,22,.70));box-shadow:0 24px 70px rgba(0,0,0,.26),inset 0 1px 0 rgba(255,255,255,.07)}
    .offerCard{padding:24px;min-height:210px}
    .offerCard small{display:grid;place-items:center;width:44px;height:44px;border:1px solid rgba(125,205,255,.32);border-radius:16px;color:#9fdcff;background:rgba(8,22,45,.72);font-weight:950;margin-bottom:18px}
    .offerCard h3{margin:0 0 10px;font-size:22px;line-height:1.14}
    .offerCard p{margin:0;color:#b8c5d6;line-height:1.55}
    .proofBand{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
    .proofItem{padding:20px}
    .proofItem b{display:block;color:#fff;margin-bottom:6px}
    .proofItem span{display:block;color:#b8c5d6;font-size:14px;line-height:1.45}
    .final{padding:70px 0 90px}
    .finalBox{border:1px solid var(--line);border-radius:34px;padding:30px;background:rgba(5,14,30,.72);display:flex;justify-content:space-between;align-items:center;gap:20px;box-shadow:0 30px 90px rgba(0,0,0,.34),inset 0 1px 0 rgba(255,255,255,.08)}
    .finalBox h2{font-size:34px;margin:0 0 8px}
    .finalBox p{margin:0;color:#b9c6d6}
    @media(max-width:980px){.heroGrid,.sectionHead,.grid,.proofBand{grid-template-columns:1fr}.visual{min-height:330px}.finalBox{display:block}.finalBox .btn{margin-top:18px}}
  </style>
</head>
<body>
  <div class="page">
    <header class="top">
      <div class="wrap nav">
        <a class="brand" href="/"><img src="/assets/optimized/assets__4.webp" alt="">Frontline AI</a>
        <a class="btn" href="/book-demo.html?product_interest=Managed%20AI%20Services">Book Fact-Find</a>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="wrap heroGrid">
          <div>
            <div class="eyebrow">Managed AI Services</div>
            <h1>Managed AI services for businesses that want <span>outcomes, not software projects.</span></h1>
            <p class="lead">Frontline AI can run practical AI services around reception, missed leads, bookings, callbacks, website assistants and growth intelligence — so the business gets results without having to operate the system itself.</p>
            <div class="actions">
              <a class="btn primary" href="/book-demo.html?product_interest=Managed%20AI%20Services">Discuss Managed Service →</a>
              <a class="btn" href="/">Back to Frontline AI</a>
            </div>
          </div>
          <div class="visual"></div>
        </div>
      </section>

      <section>
        <div class="wrap">
          <div class="sectionHead">
            <h2>What this includes.</h2>
            <p>This is a draft commercial page so the offer is visible in the menu now. We can replace sections with real proof, screenshots and campaign results as we build it out.</p>
          </div>
          <div class="grid">
            <article class="offerCard">
          <small>01</small>
          <h3>Managed AI Reception</h3>
          <p>Capture calls, enquiries and callbacks with a supported AI front-office layer.</p>
        </article>
<article class="offerCard">
          <small>02</small>
          <h3>Managed Booking & Callback Handling</h3>
          <p>Keep appointment requests, quote enquiries and follow-ups moving.</p>
        </article>
<article class="offerCard">
          <small>03</small>
          <h3>Managed RAG Website Assistant</h3>
          <p>Operate an approved-knowledge assistant for website visitors and document-led questions.</p>
        </article>
<article class="offerCard">
          <small>04</small>
          <h3>Monthly AI Operations Support</h3>
          <p>Review usage, improve prompts, update flows and keep the service useful.</p>
        </article>
<article class="offerCard">
          <small>05</small>
          <h3>Managed Ad Engine</h3>
          <p>Competitor monitoring, campaign angles and growth intelligence as an ongoing service.</p>
        </article>
<article class="offerCard">
          <small>06</small>
          <h3>Reporting & Improvement</h3>
          <p>Monthly visibility into activity, opportunities and improvements.</p>
        </article>
          </div>
        </div>
      </section>

      <section>
        <div class="wrap">
          <div class="sectionHead">
            <h2>Proof slots ready to fill.</h2>
            <p>Designed to accept real results, dashboards, examples, before/after comparisons and screenshots as they become available.</p>
          </div>
          <div class="proofBand">
            <div class="proofItem">
          <b>Service reports</b>
          <span>Monthly activity and improvement summaries.</span>
        </div>
<div class="proofItem">
          <b>Human escalation</b>
          <span>Clear handoff rules where AI should not decide.</span>
        </div>
<div class="proofItem">
          <b>Content updates</b>
          <span>Keep approved knowledge and workflows fresh.</span>
        </div>
<div class="proofItem">
          <b>Practical outcomes</b>
          <span>Calls, bookings, leads, callbacks and enquiries.</span>
        </div>
          </div>
        </div>
      </section>

      <section class="final">
        <div class="wrap finalBox">
          <div>
            <h2>Start with a focused fact-find.</h2>
            <p>We can scope the first version, then add evidence, visuals and stronger proof sections.</p>
          </div>
          <a class="btn primary" href="/book-demo.html?product_interest=Managed%20AI%20Services">Discuss Managed Service →</a>
        </div>
      </section>
    </main>
  </div>
  <script defer src="/assets/frontline-menu.js?v=20260521-menu-exact-v2"></script>
  <script defer src="/assets/frontline-assistant.js?v=20260520-frontline-assistant-v1"></script>
</body>
</html>
